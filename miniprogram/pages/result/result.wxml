<view class="sketch-desk" wx:if="{{result}}">
  <view class="sketch-window">
    <view class="corner-tick ct-tl"></view>
    <view class="corner-tick ct-tr"></view>
    <view class="corner-tick ct-bl"></view>
    <view class="corner-tick ct-br"></view>

    <view class="sketch-titlebar">
      <text class="stb-text">📋 诊断报告</text>
      <view class="stb-btns">
        <view class="stb-btn">_</view>
        <view class="stb-btn">□</view>
        <view class="stb-btn stb-close">×</view>
      </view>
    </view>

    <view class="sketch-body">
      <!-- Report card -->
      <view class="report-sketch">
        <view class="rs-header">
          <text class="rs-label">BMTI 系统诊断报告 v1.0</text>
          <view class="rs-divider"></view>
        </view>

        <view class="rs-section">
          <text class="rs-tag">// 型号识别</text>
          <text class="rs-model" style="color: var(--bsod-blue)">{{result.name}}</text>
        </view>

        <view class="rs-divider"></view>

        <view class="rs-section">
          <text class="rs-tag">// 系统诊断</text>
          <text class="rs-text">{{result.diagnosis}}</text>
        </view>

        <view class="rs-section">
          <text class="rs-tag">// 已知Bug</text>
          <text class="rs-text rs-italic">{{result.tagline}}</text>
        </view>

        <view class="rs-footer">
          <text class="rs-code">Diagnostic Code: 0x0000{{result.id < 10 ? '0' : ''}}{{result.id}}</text>
          <text class="rs-time">{{currentTime}}</text>
        </view>
      </view>

      <!-- Primary CTA -->
      <button class="sketch-btn sketch-btn-primary" bindtap="onOpenColorMode">
        🖥 显示校准 · 生成专属光谱
      </button>

      <!-- Secondary -->
      <view class="sec-row">
        <button class="sketch-btn-sec" open-type="share">发送给懂你Bug的人</button>
        <view class="retake-link" bindtap="onRetake">
          <text class="retake-txt">重新扫描</text>
        </view>
      </view>
    </view>
  </view>
</view>
