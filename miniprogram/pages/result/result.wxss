.sketch-desk {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.sketch-window {
  width: 640rpx;
  max-height: 85vh;
  background: rgba(255,255,255,0.75);
  border: 3rpx dashed var(--sketch-color);
  position: relative;
  transform: rotate(-0.2deg);
  display: flex; flex-direction: column;
}

.corner-tick { position: absolute; width: 24rpx; height: 24rpx; z-index: 2; }
.ct-tl { top: -2rpx; left: -2rpx; border-top: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-tr { top: -2rpx; right: -2rpx; border-top: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }
.ct-bl { bottom: -2rpx; left: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-br { bottom: -2rpx; right: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }

.sketch-titlebar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 20rpx;
  border-bottom: 2rpx dashed var(--sketch-color);
  background: linear-gradient(180deg, rgba(47,113,216,0.12) 0%, rgba(47,113,216,0.03) 100%);
  flex-shrink: 0;
}

.stb-text { font-size: 22rpx; font-weight: 700; color: var(--ink); }
.stb-btns { display: flex; gap: 6rpx; }

.stb-btn {
  width: 32rpx; height: 32rpx;
  border: 1.5rpx dashed var(--sketch-color);
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: var(--ink-light);
  transform: rotate(-2deg);
}
.stb-close { border-color: #E85030; color: #E85030; }

.sketch-body { padding: 24rpx 28rpx; overflow-y: auto; flex: 1; }

/* Report card */
.report-sketch {
  background: rgba(255,255,255,0.7);
  border: 1.5rpx dashed var(--sketch-light);
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  transform: rotate(-0.15deg);
}

.rs-header { margin-bottom: 18rpx; }

.rs-label {
  font-size: 18rpx; font-weight: 700; color: var(--bsod-blue);
  font-family: var(--font-mono); letter-spacing: 2rpx;
  text-transform: uppercase;
}

.rs-divider {
  height: 0;
  border-top: 1.5rpx dashed var(--sketch-light);
  margin: 14rpx 0;
}

.rs-section { margin-bottom: 14rpx; }

.rs-tag {
  display: block;
  font-size: 16rpx; color: var(--ink-faint);
  font-family: var(--font-mono); letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}

.rs-model {
  font-size: 34rpx; font-weight: 800; line-height: 1.3;
}

.rs-text {
  font-size: 22rpx; color: var(--ink); line-height: 1.7;
}

.rs-italic { font-style: italic; color: var(--ink-light); }

.rs-footer { margin-top: 12rpx; }

.rs-code {
  display: block; font-size: 16rpx; color: var(--ink-faint);
  font-family: var(--font-mono);
}

.rs-time {
  display: block; font-size: 16rpx; color: var(--ink-faint);
  font-family: var(--font-mono);
}

/* Primary button */
.sketch-btn {
  width: 100%;
  padding: 22rpx 0;
  background: rgba(255,255,255,0.7);
  border: 2.5rpx dashed var(--sketch-color);
  transform: rotate(-0.15deg);
  border-radius: 0;
  font-size: 26rpx;
  color: var(--ink);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sketch-btn-primary {
  border-color: var(--bsod-blue);
  background: rgba(51,85,170,0.06);
}

.sketch-btn-primary:active {
  background: rgba(51,85,170,0.18);
}

/* Secondary row */
.sec-row {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}

.sketch-btn-sec {
  background: transparent;
  border: 1.5rpx dashed var(--sketch-light);
  padding: 12rpx 32rpx;
  font-size: 20rpx;
  color: var(--ink-light);
  border-radius: 0;
}

.sketch-btn-sec:active {
  background: rgba(200,212,232,0.2);
}

.retake-link { padding: 8rpx 0; }

.retake-txt {
  font-size: 18rpx; color: var(--ink-faint);
}
