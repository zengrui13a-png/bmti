<view class="neon-desk" wx:if="{{question}}">
  <view class="neon-window">
    <view class="corner-tick ct-tl"></view>
    <view class="corner-tick ct-tr"></view>
    <view class="corner-tick ct-bl"></view>
    <view class="corner-tick ct-br"></view>

    <view class="neon-titlebar">
      <text class="ntb-text">🖥 显示校准向导</text>
      <view class="ntb-btns">
        <view class="ntb-dot"></view>
        <view class="ntb-dot"></view>
        <view class="ntb-dot ntb-active"></view>
      </view>
    </view>

    <view class="neon-body">
      <!-- Channel badge -->
      <view class="nchan-badge">
        <text class="nchan-code">{{question.channelName}}</text>
        <text class="nchan-step">{{currentIndex + 1}}/{{totalQuestions}}</text>
      </view>

      <!-- Progress -->
      <view class="nprog-track">
        <view class="nprog-fill" style="width: {{(currentIndex + 1) / totalQuestions * 100}}%"></view>
      </view>

      <!-- Question -->
      <text class="nq-text">{{question.text}}</text>

      <!-- Options -->
      <view class="nopts">
        <view
          class="nopt {{selectedIndex === index ? 'nopt-sel' : ''}}"
          wx:for="{{question.options}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onSelectOption"
        >
          <view class="nopt-marker">{{selectedIndex === index ? '◆' : '◇'}}</view>
          <view class="nopt-body">
            <text class="nopt-label">{{item.label}}</text>
            <text class="nopt-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- Button -->
      <button
        class="neon-btn {{selectedIndex >= 0 ? 'neon-btn-ok' : ''}}"
        bindtap="onNextStep"
        disabled="{{selectedIndex < 0}}"
      >
        {{currentIndex + 1 >= totalQuestions ? '▸ 生成光谱报告' : '▸ 确认采样'}}
      </button>
    </view>
  </view>
</view>
