<view class="cyber-screen" wx:if="{{question}}">
  <view class="cyber-bg-overlay">
    <view class="cyber-bg-dots"></view>
    <view class="cyber-bg-gradient"></view>
  </view>

  <view class="cyber-panel">
    <view class="cyber-panel-header">
      <text class="cyber-panel-label">SPECTRAL CALIBRATION</text>
      <view class="cyber-panel-divider">
        <view class="cp-dot"></view>
        <view class="cp-line"></view>
        <view class="cp-dot"></view>
      </view>
    </view>

    <view class="cyber-panel-body">
      <!-- Channel badge + progress -->
      <view class="channel-header">
        <view class="channel-badge">
          <text class="channel-code">{{question.channelName}}</text>
        </view>
        <text class="channel-step">{{currentIndex + 1}} / {{totalQuestions}}</text>
      </view>

      <view class="cyber-progress">
        <view class="cyber-progress-fill" style="width: {{(currentIndex + 1) / totalQuestions * 100}}%"></view>
      </view>

      <!-- Question -->
      <text class="cyber-question">{{question.text}}</text>

      <!-- Options -->
      <view class="cyber-options">
        <view
          class="cyber-opt {{selectedIndex === index ? 'cyber-opt-active' : ''}}"
          wx:for="{{question.options}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onSelectOption"
        >
          <view class="cyber-opt-marker">{{selectedIndex === index ? '◆' : '◇'}}</view>
          <view class="cyber-opt-body">
            <text class="cyber-opt-label">{{item.label}}</text>
            <text class="cyber-opt-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- Button -->
      <view class="cyber-btn-wrap">
        <button
          class="cyber-btn {{selectedIndex >= 0 ? 'cyber-btn-ready' : ''}}"
          bindtap="onNextStep"
          disabled="{{selectedIndex < 0}}"
        >
          <text>{{currentIndex + 1 >= totalQuestions ? '▸ 生成光谱报告' : '▸ 确认采样'}}</text>
        </button>
      </view>
    </view>
  </view>
</view>
