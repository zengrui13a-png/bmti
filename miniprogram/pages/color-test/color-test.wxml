<view class="xp-desktop">
  <view class="xp-window">
    <view class="xp-titlebar">
      <text class="xp-title-icon">🎨</text>
      <text class="xp-title-text">光谱校准</text>
      <view class="xp-title-btns">
        <view class="xp-btn-min">_</view>
        <view class="xp-btn-max">□</view>
        <view class="xp-btn-close">×</view>
      </view>
    </view>
    <view class="xp-body">
      <view class="scan-header">
        <text class="scan-label">色彩采样 {{currentIndex + 1}}/{{totalQuestions}}</text>
        <text class="channel-tag">{{question.channel}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{(currentIndex + 1) / totalQuestions * 100}}%"></view>
      </view>

      <view class="question-area" wx:if="{{question}}">
        <view class="dim-meta">
          <text class="dim-module">{{question.channelName}}</text>
          <text class="dim-tagline">{{question.tagline}}</text>
        </view>
        <text class="q-text">{{question.text}}</text>
      </view>

      <view class="options-list">
        <view
          class="opt-item {{selectedIndex === index ? 'opt-selected' : ''}}"
          wx:for="{{question.options}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onSelectOption"
        >
          <view class="opt-radio">{{selectedIndex === index ? '●' : '○'}}</view>
          <view class="opt-content">
            <text class="opt-label">{{item.label}}</text>
            <text class="opt-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <button
        class="xp-btn-primary {{selectedIndex < 0 ? 'btn-disabled' : ''}}"
        bindtap="onNextStep"
        disabled="{{selectedIndex < 0}}"
      >
        {{currentIndex + 1 >= totalQuestions ? '生成光谱' : '继续采样'}}
      </button>
    </view>
  </view>
</view>
