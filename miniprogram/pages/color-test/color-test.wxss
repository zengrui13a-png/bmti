.neon-desk {
  min-height: 100vh;
  background: var(--paper-warm);
  display: flex; align-items: center; justify-content: center;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
}

.neon-window {
  width: 640rpx;
  background: rgba(255,255,255,0.8);
  border: 2.5rpx dashed var(--sketch-color);
  position: relative;
  transform: rotate(-0.15deg);
}

.corner-tick { position: absolute; width: 20rpx; height: 20rpx; z-index: 2; }
.ct-tl { top: -2rpx; left: -2rpx; border-top: 2.5rpx solid var(--neon-blue); border-left: 2.5rpx solid var(--neon-blue); }
.ct-tr { top: -2rpx; right: -2rpx; border-top: 2.5rpx solid var(--neon-pink); border-right: 2.5rpx solid var(--neon-pink); }
.ct-bl { bottom: -2rpx; left: -2rpx; border-bottom: 2.5rpx solid var(--neon-green); border-left: 2.5rpx solid var(--neon-green); }
.ct-br { bottom: -2rpx; right: -2rpx; border-bottom: 2.5rpx solid var(--neon-red); border-right: 2.5rpx solid var(--neon-red); }

.neon-titlebar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14rpx 24rpx;
  border-bottom: 2rpx dashed var(--sketch-light);
}

.ntb-text { font-size: 22rpx; font-weight: 700; color: var(--ink); font-family: var(--font-mono); }

.ntb-btns { display: flex; gap: 8rpx; }

.ntb-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  border: 1.5rpx solid var(--sketch-light);
}
.ntb-active {
  background: var(--neon-blue);
  border-color: var(--neon-blue);
  box-shadow: 0 0 8rpx var(--neon-glow-blue);
}

.neon-body { padding: 28rpx 28rpx 24rpx; }

/* Channel badge */
.nchan-badge {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 18rpx;
}

.nchan-code {
  font-size: 22rpx; font-family: var(--font-mono); font-weight: 700;
  color: var(--neon-blue); letter-spacing: 2rpx;
  text-shadow: 0 0 8rpx var(--neon-glow-blue);
}

.nchan-step {
  font-size: 18rpx; font-family: var(--font-mono); color: var(--ink-faint);
}

/* Progress */
.nprog-track {
  height: 5rpx;
  background: rgba(200,212,232,0.4);
  border-radius: 3rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
}

.nprog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-blue), var(--neon-pink));
  box-shadow: 0 0 10rpx var(--neon-glow-blue);
  transition: width 0.3s ease;
}

/* Question */
.nq-text {
  display: block;
  font-size: 28rpx; font-weight: 600; color: var(--ink);
  line-height: 1.5; margin-bottom: 24rpx;
}

/* Options */
.nopts {
  display: flex; flex-direction: column; gap: 12rpx;
  margin-bottom: 28rpx;
}

.nopt {
  display: flex; align-items: flex-start; gap: 14rpx;
  padding: 22rpx 20rpx;
  background: rgba(255,255,255,0.7);
  border: 1.5rpx dashed var(--sketch-light);
  transform: rotate(-0.08deg);
}

.nopt-sel {
  background: rgba(56,152,208,0.05);
  border-color: var(--neon-blue);
  border-style: solid;
  box-shadow: 0 0 18rpx var(--neon-glow-blue), inset 0 0 12rpx rgba(56,152,208,0.04);
}

.nopt-marker {
  font-size: 24rpx; color: var(--sketch-light); flex-shrink: 0; margin-top: 2rpx;
}
.nopt-sel .nopt-marker { color: var(--neon-blue); }

.nopt-body { flex: 1; }

.nopt-label {
  display: block; font-size: 24rpx; font-weight: 600; color: var(--ink); line-height: 1.4;
}

.nopt-desc {
  display: block; font-size: 18rpx; color: var(--ink-light); line-height: 1.4; margin-top: 4rpx;
}

/* Button */
.neon-btn {
  width: 100%;
  padding: 22rpx 0;
  background: rgba(255,255,255,0.8);
  border: 2rpx dashed var(--sketch-light);
  font-size: 24rpx;
  color: var(--ink-faint);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  border-radius: 0;
  transform: rotate(-0.1deg);
}

.neon-btn-ok {
  border-color: var(--neon-blue);
  border-style: solid;
  color: var(--neon-blue);
  box-shadow: 0 0 16rpx var(--neon-glow-blue);
}

.neon-btn-ok:active {
  background: rgba(56,152,208,0.1);
  box-shadow: 0 0 24rpx var(--neon-glow-blue);
}
