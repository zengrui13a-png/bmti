/* === CYBERPUNK COLOR CALIBRATION SCREEN === */

.cyber-screen {
  min-height: 100vh;
  background: #07080D;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* Subtle background texture */
.cyber-bg-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  pointer-events: none;
}

.cyber-bg-dots {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.25;
  background-image:
    radial-gradient(circle, rgba(255,255,255,0.3) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
}

.cyber-bg-gradient {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(45,55,90,0.4) 0%, transparent 70%);
}

/* === PANEL === */
.cyber-panel {
  width: 640rpx;
  background: rgba(14,18,26,0.9);
  border: 1rpx solid rgba(255,255,255,0.08);
  position: relative;
  z-index: 1;
}

.cyber-panel-header {
  padding: 36rpx 36rpx 0;
  text-align: center;
}

.cyber-panel-label {
  font-size: 20rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.4);
  letter-spacing: 8rpx;
}

.cyber-panel-divider {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.cp-dot {
  width: 6rpx; height: 6rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
}

.cp-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
}

.cyber-panel-body {
  padding: 32rpx 36rpx 36rpx;
}

/* === CHANNEL HEADER === */
.channel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.channel-badge {
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.channel-code {
  font-size: 18rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.7);
  letter-spacing: 2rpx;
}

.channel-step {
  font-size: 20rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.3);
}

/* === PROGRESS === */
.cyber-progress {
  height: 3rpx;
  background: rgba(255,255,255,0.06);
  margin-bottom: 36rpx;
}

.cyber-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.2), rgba(255,255,255,0.6));
  transition: width 0.3s ease;
}

/* === QUESTION === */
.cyber-question {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
  margin-bottom: 28rpx;
}

/* === OPTIONS === */
.cyber-options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 32rpx;
}

.cyber-opt {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
}

.cyber-opt-active {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.25);
}

.cyber-opt-marker {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.cyber-opt-active .cyber-opt-marker {
  color: rgba(255,255,255,0.9);
}

.cyber-opt-body {
  flex: 1;
}

.cyber-opt-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}

.cyber-opt-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  line-height: 1.4;
  margin-top: 4rpx;
}

/* === BUTTON === */
.cyber-btn-wrap {
  display: flex;
  justify-content: center;
}

.cyber-btn {
  width: 100%;
  padding: 24rpx 0;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.12);
  font-size: 26rpx;
  font-family: var(--font-mono);
  font-weight: 600;
  color: rgba(255,255,255,0.3);
  letter-spacing: 4rpx;
  border-radius: 0;
}

.cyber-btn-ready {
  color: rgba(255,255,255,0.9);
  border-color: rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.06);
}

.cyber-btn-ready:active {
  background: rgba(255,255,255,0.14);
  border-color: rgba(255,255,255,0.6);
}
