.sketch-desk {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.sketch-window {
  width: 640rpx;
  background: rgba(255,255,255,0.7);
  border: 3rpx dashed var(--sketch-color);
  position: relative;
  transform: rotate(-0.2deg);
}

.corner-tick {
  position: absolute;
  width: 24rpx; height: 24rpx;
  z-index: 2;
}
.ct-tl { top: -2rpx; left: -2rpx; border-top: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-tr { top: -2rpx; right: -2rpx; border-top: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }
.ct-bl { bottom: -2rpx; left: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-br { bottom: -2rpx; right: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }

.sketch-titlebar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  border-bottom: 2rpx dashed var(--sketch-color);
  background: linear-gradient(180deg, rgba(47,113,216,0.12) 0%, rgba(47,113,216,0.03) 100%);
}

.stb-text { font-size: 22rpx; font-weight: 700; color: var(--ink); }
.stb-btns { display: flex; gap: 6rpx; }

.stb-btn {
  width: 32rpx; height: 32rpx;
  border: 1.5rpx dashed var(--sketch-color);
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: var(--ink-light);
  transform: rotate(-2deg);
}
.stb-close { border-color: #E85030; color: #E85030; }

.sketch-body { padding: 28rpx 28rpx 24rpx; }

/* Progress — hatch fill */
.prog-header {
  display: flex; justify-content: space-between;
  margin-bottom: 8rpx;
}
.prog-label { font-size: 18rpx; color: var(--ink-light); font-family: var(--font-mono); }
.prog-pct { font-size: 18rpx; font-weight: 700; color: var(--ink); font-family: var(--font-mono); }

.prog-track {
  height: 16rpx;
  background: rgba(200,212,232,0.3);
  border: 1.5rpx dashed var(--sketch-light);
  margin-bottom: 28rpx;
  overflow: hidden;
}

.prog-hatch {
  height: 100%;
  background: repeating-linear-gradient(
    -45deg,
    var(--bsod-blue),
    var(--bsod-blue) 4rpx,
    rgba(51,85,170,0.5) 4rpx,
    rgba(51,85,170,0.5) 8rpx
  );
  transition: width 0.3s ease;
}

/* Module header */
.module-header {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  border-left: 3rpx solid var(--bsod-blue);
}

.module-file {
  display: block;
  font-size: 18rpx;
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--bsod-blue);
  letter-spacing: 1rpx;
  margin-bottom: 4rpx;
}

.module-desc {
  display: block;
  font-size: 18rpx;
  color: var(--ink-light);
  line-height: 1.5;
  font-style: italic;
}

/* Question */
.q-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

/* Options */
.opts {
  display: flex; flex-direction: column; gap: 14rpx;
  margin-bottom: 28rpx;
}

.opt-card {
  display: flex; align-items: flex-start; gap: 14rpx;
  padding: 22rpx 20rpx;
  background: rgba(255,255,255,0.6);
  border: 1.5rpx dashed var(--sketch-light);
  transform: rotate(-0.1deg);
}

.opt-picked {
  background: rgba(51,85,170,0.06);
  border-color: var(--bsod-blue);
  border-style: solid;
}

.opt-marker {
  font-size: 26rpx; color: var(--sketch-color); flex-shrink: 0; margin-top: 2rpx;
}
.opt-picked .opt-marker { color: var(--bsod-blue); }

.opt-body { flex: 1; }

.opt-label {
  display: block;
  font-size: 24rpx; font-weight: 600; color: var(--ink); line-height: 1.4;
}

.opt-hint {
  display: block;
  font-size: 18rpx; color: var(--ink-light); line-height: 1.4; margin-top: 4rpx;
}

/* Button */
.sketch-btn {
  width: 100%;
  padding: 22rpx 0;
  background: rgba(255,255,255,0.7);
  border: 2rpx dashed var(--sketch-light);
  transform: rotate(-0.15deg);
  border-radius: 0;
  font-size: 26rpx;
  color: var(--ink-faint);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.sketch-btn-ok {
  border-color: var(--sketch-color);
  color: var(--ink);
  background: rgba(51,85,170,0.06);
}

.sketch-btn-ok:active {
  background: rgba(51,85,170,0.15);
}
