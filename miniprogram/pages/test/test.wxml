<view class="sketch-desk">
  <view class="sketch-window">
    <view class="corner-tick ct-tl"></view>
    <view class="corner-tick ct-tr"></view>
    <view class="corner-tick ct-bl"></view>
    <view class="corner-tick ct-br"></view>

    <view class="sketch-titlebar">
      <text class="stb-text">系统诊断中...</text>
      <view class="stb-btns">
        <view class="stb-btn">_</view>
        <view class="stb-btn">□</view>
        <view class="stb-btn stb-close">×</view>
      </view>
    </view>

    <view class="sketch-body">
      <!-- Progress -->
      <view class="prog-header">
        <text class="prog-label">扫描扇区 {{currentIndex + 1}}/{{totalQuestions}}</text>
        <text class="prog-pct">{{progress}}%</text>
      </view>
      <view class="prog-track">
        <view class="prog-hatch" style="width: {{progress}}%"></view>
      </view>

      <!-- Module header -->
      <view class="module-header" wx:if="{{question}}">
        <text class="module-file">{{question.module}}</text>
        <text class="module-desc">{{question.desc}}</text>
      </view>

      <!-- Question -->
      <text class="q-text" wx:if="{{question}}">{{question.text}}</text>

      <!-- Options -->
      <view class="opts">
        <view
          class="opt-card {{selectedIndex === index ? 'opt-picked' : ''}}"
          wx:for="{{question.options}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onSelectOption"
        >
          <view class="opt-marker">{{selectedIndex === index ? '●' : '○'}}</view>
          <view class="opt-body">
            <text class="opt-label">{{item.label}}</text>
            <text class="opt-hint">{{item.hint}}</text>
          </view>
        </view>
      </view>

      <!-- Button -->
      <button
        class="sketch-btn {{selectedIndex >= 0 ? 'sketch-btn-ok' : ''}}"
        bindtap="onNextStep"
        disabled="{{selectedIndex < 0}}"
      >
        {{currentIndex + 1 >= totalQuestions ? '完成诊断' : '下一步'}}
      </button>
    </view>
  </view>
</view>
