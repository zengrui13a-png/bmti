.sketch-desk {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
}

/* Sketch window — dashed border + subtle rotation */
.sketch-window {
  width: 640rpx;
  background: rgba(255,255,255,0.7);
  border: 3rpx dashed var(--sketch-color);
  padding: 0;
  position: relative;
  transform: rotate(-0.25deg);
}

/* Corner tick marks — blueprint annotation style */
.corner-tick {
  position: absolute;
  width: 24rpx; height: 24rpx;
  z-index: 2;
}
.ct-tl { top: -2rpx; left: -2rpx; border-top: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-tr { top: -2rpx; right: -2rpx; border-top: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }
.ct-bl { bottom: -2rpx; left: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-left: 3rpx solid var(--sketch-color); }
.ct-br { bottom: -2rpx; right: -2rpx; border-bottom: 3rpx solid var(--sketch-color); border-right: 3rpx solid var(--sketch-color); }

/* Title bar — XP sketch style */
.sketch-titlebar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  border-bottom: 2rpx dashed var(--sketch-color);
  background: linear-gradient(180deg, rgba(47,113,216,0.15) 0%, rgba(47,113,216,0.05) 100%);
}

.stb-text {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ink);
  font-family: var(--font-sketch);
}

.stb-btns { display: flex; gap: 6rpx; }

.stb-btn {
  width: 32rpx; height: 32rpx;
  border: 1.5rpx dashed var(--sketch-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: var(--ink-light);
  transform: rotate(-2deg);
}

.stb-close { border-color: #E85030; color: #E85030; }

/* BSOD sketch block */
.bsod-sketch {
  margin: 32rpx 28rpx;
  padding: 36rpx 28rpx;
  background: var(--bsod-blue);
  border: 2rpx dashed rgba(255,255,255,0.3);
  transform: rotate(0.15deg);
}

.bsod-title {
  display: block;
  font-size: 64rpx;
  font-weight: 900;
  color: var(--bsod-text);
  font-family: var(--font-mono);
  letter-spacing: 10rpx;
  margin-bottom: 8rpx;
}

.bsod-sub {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.bsod-line {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
}

.bsod-accent {
  color: #AACCFF;
  font-weight: 600;
}

/* Info */
.sketch-info {
  margin: 0 28rpx 32rpx;
  padding: 20rpx 24rpx;
  border: 1.5rpx dashed var(--sketch-light);
}

.si-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.si-bullet {
  font-size: 20rpx;
  color: var(--sketch-color);
}

.si-text {
  font-size: 22rpx;
  color: var(--ink-light);
}

/* Button */
.sketch-btn {
  margin: 0 28rpx 32rpx;
  width: auto;
  display: block;
  padding: 22rpx 0;
  background: rgba(255,255,255,0.8);
  border: 2.5rpx dashed var(--sketch-color);
  transform: rotate(-0.2deg);
  border-radius: 0;
}

.sketch-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.sketch-btn:active {
  background: rgba(200,212,232,0.3);
}
