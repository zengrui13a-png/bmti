/* === CYBERPUNK RESULT SCREEN === */

.cyber-screen {
  min-height: 100vh;
  background: #0A0A0A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  position: relative;
}

/* === THREE-LAYER BACKGROUND === */
.color-bg-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.bg-color-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.70;
}

.bg-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse 55% 45% at 38% 32%, rgba(255,255,255,0.35) 0%, transparent 60%);
}

.bg-rays {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.5;
  background: conic-gradient(
    from 0deg at 50% 50%,
    rgba(255,255,255,0.03) 0deg, transparent 2deg,
    rgba(255,255,255,0.03) 4deg, transparent 6deg,
    rgba(255,255,255,0.03) 8deg, transparent 10deg,
    rgba(255,255,255,0.03) 12deg, transparent 14deg,
    rgba(255,255,255,0.03) 16deg, transparent 18deg,
    rgba(255,255,255,0.03) 20deg, transparent 22deg,
    rgba(255,255,255,0.03) 24deg, transparent 26deg,
    rgba(255,255,255,0.03) 28deg, transparent 30deg,
    rgba(255,255,255,0.03) 32deg, transparent 34deg,
    rgba(255,255,255,0.03) 36deg, transparent 38deg,
    rgba(255,255,255,0.03) 40deg, transparent 42deg,
    rgba(255,255,255,0.03) 44deg, transparent 46deg,
    rgba(255,255,255,0.03) 48deg, transparent 50deg,
    rgba(255,255,255,0.03) 52deg, transparent 54deg,
    rgba(255,255,255,0.03) 56deg, transparent 58deg,
    rgba(255,255,255,0.03) 60deg, transparent 62deg,
    rgba(255,255,255,0.03) 64deg, transparent 66deg,
    rgba(255,255,255,0.03) 68deg, transparent 70deg,
    rgba(255,255,255,0.03) 72deg, transparent 74deg,
    rgba(255,255,255,0.03) 76deg, transparent 78deg,
    rgba(255,255,255,0.03) 80deg, transparent 82deg,
    rgba(255,255,255,0.03) 84deg, transparent 86deg,
    rgba(255,255,255,0.03) 88deg, transparent 90deg
  );
}

/* === MAIN CARD === */
.cyber-card {
  width: 640rpx;
  background: rgba(13,17,23,0.85);
  border: 2rpx solid rgba(255,255,255,0.12);
  position: relative;
  z-index: 1;
  overflow: hidden;
  padding: 0;
}

/* Corner accents */
.card-corner {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  z-index: 2;
  pointer-events: none;
}
.card-corner-tl { top: 0; left: 0; border-top: 4rpx solid rgba(255,255,255,0.5); border-left: 4rpx solid rgba(255,255,255,0.5); }
.card-corner-tr { top: 0; right: 0; border-top: 4rpx solid rgba(255,255,255,0.5); border-right: 4rpx solid rgba(255,255,255,0.5); }
.card-corner-bl { bottom: 0; left: 0; border-bottom: 4rpx solid rgba(255,255,255,0.5); border-left: 4rpx solid rgba(255,255,255,0.5); }
.card-corner-br { bottom: 0; right: 0; border-bottom: 4rpx solid rgba(255,255,255,0.5); border-right: 4rpx solid rgba(255,255,255,0.5); }

/* Scanline overlay */
.scanline {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 4rpx,
    rgba(255,255,255,0.015) 4rpx,
    rgba(255,255,255,0.015) 8rpx
  );
  z-index: 1;
  pointer-events: none;
}

/* === CARD CONTENT === */
.card-header {
  padding: 40rpx 36rpx 0;
  z-index: 3;
  position: relative;
}

.cyber-label {
  display: block;
  font-size: 20rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.5);
  letter-spacing: 6rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.cyber-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.divider-dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
  flex-shrink: 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.3), transparent 50%, rgba(255,255,255,0.3));
}

.card-body {
  padding: 32rpx 36rpx 36rpx;
  z-index: 3;
  position: relative;
}

.cyber-tag {
  display: block;
  font-size: 18rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.35);
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

/* Model name */
.model-section {
  margin-bottom: 28rpx;
}

.model-name {
  font-size: 44rpx;
  font-weight: 800;
  font-family: var(--font-sans);
  letter-spacing: 4rpx;
  line-height: 1.2;
}

/* Spectrum bar */
.spectrum-section {
  margin-bottom: 28rpx;
}

.spectrum-bar {
  display: flex;
  height: 12rpx;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.rgba-value {
  font-size: 22rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.6);
  letter-spacing: 2rpx;
}

/* Diagnosis */
.diagnosis-section {
  margin-bottom: 24rpx;
}

.diagnosis-text {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.8);
  line-height: 1.7;
  font-family: var(--font-sans);
}

/* Note */
.note-section {
  margin-bottom: 24rpx;
}

.note-text {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.55);
  font-style: italic;
  line-height: 1.6;
}

/* Card footer */
.card-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.footer-hash {
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.25);
}

.footer-id {
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.25);
}

/* === ACTION BUTTONS === */
.action-row {
  position: relative;
  z-index: 1;
  width: 640rpx;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.cyber-btn-share {
  width: 100%;
  padding: 26rpx 0;
  background: transparent;
  border: 2rpx solid rgba(255,255,255,0.3);
  font-size: 28rpx;
  font-family: var(--font-mono);
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  letter-spacing: 4rpx;
  position: relative;
  overflow: hidden;
  border-radius: 0;
}

.cyber-btn-share:active {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.6);
}

.btn-text {
  position: relative;
  z-index: 1;
}

.xp-btn-toggle {
  background: transparent;
  border: none;
  padding: 8rpx 0;
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.35);
  letter-spacing: 2rpx;
}
