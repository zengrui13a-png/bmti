/* === CYBERPUNK RESULT — DYNAMIC COLOR BACKGROUND === */

.cyber-screen {
  min-height: 100vh;
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* === MULTI-LAYER DYNAMIC BACKGROUND === */
.color-bg-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  pointer-events: none;
}

/* Gradient Layer 1: Dominant glow from upper-left — highest opacity */
.bg-gradient-1 {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.95;
  z-index: 1;
}

/* Gradient Layer 2: Cool secondary from lower-right */
.bg-gradient-2 {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.8;
  z-index: 2;
}

/* Gradient Layer 3: Complementary accent */
.bg-gradient-3 {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.5;
  z-index: 3;
}

/* Pulsing glow overlay */
.bg-glow-pulse {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.25;
  z-index: 4;
  background: radial-gradient(ellipse 50% 40% at 40% 30%, rgba(255,255,255,0.5) 0%, transparent 65%);
  animation: glowBreathe 4s ease-in-out infinite;
}

@keyframes glowBreathe {
  0%, 100% { opacity: 0.15; transform: scale(1); }
  50% { opacity: 0.40; transform: scale(1.06); }
}

/* Rotating ray texture */
.bg-rays-rotate {
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  opacity: 0.35;
  z-index: 5;
  background: conic-gradient(
    from 0deg at 50% 50%,
    rgba(255,255,255,0.03) 0deg, transparent 2deg,
    rgba(255,255,255,0.03) 4deg, transparent 6deg,
    rgba(255,255,255,0.03) 8deg, transparent 10deg,
    rgba(255,255,255,0.03) 12deg, transparent 14deg,
    rgba(255,255,255,0.03) 16deg, transparent 18deg,
    rgba(255,255,255,0.03) 20deg, transparent 22deg,
    rgba(255,255,255,0.03) 24deg, transparent 26deg,
    rgba(255,255,255,0.03) 28deg, transparent 30deg,
    rgba(255,255,255,0.03) 32deg, transparent 34deg,
    rgba(255,255,255,0.03) 36deg, transparent 38deg,
    rgba(255,255,255,0.03) 40deg, transparent 42deg,
    rgba(255,255,255,0.03) 44deg, transparent 46deg,
    rgba(255,255,255,0.03) 48deg, transparent 50deg,
    rgba(255,255,255,0.03) 52deg, transparent 54deg,
    rgba(255,255,255,0.03) 56deg, transparent 58deg,
    rgba(255,255,255,0.03) 60deg, transparent 62deg,
    rgba(255,255,255,0.03) 64deg, transparent 66deg,
    rgba(255,255,255,0.03) 68deg, transparent 70deg,
    rgba(255,255,255,0.03) 72deg, transparent 74deg,
    rgba(255,255,255,0.03) 76deg, transparent 78deg,
    rgba(255,255,255,0.03) 80deg, transparent 82deg,
    rgba(255,255,255,0.03) 84deg, transparent 86deg,
    rgba(255,255,255,0.03) 88deg, transparent 90deg
  );
  animation: raysSpin 60s linear infinite;
}

@keyframes raysSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* === FLOATING PARTICLES === */
.particles {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  pointer-events: none;
}

.particle {
  position: absolute;
  width: 4rpx; height: 4rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 50%;
  animation: floatUp 6s ease-in infinite;
}

.p1 { left: 15%; animation-duration: 7s; animation-delay: 0s; }
.p2 { left: 35%; animation-duration: 5s; animation-delay: 1.5s; width: 3rpx; height: 3rpx; }
.p3 { left: 60%; animation-duration: 8s; animation-delay: 3s; }
.p4 { left: 78%; animation-duration: 6s; animation-delay: 2s; width: 2rpx; height: 2rpx; }
.p5 { left: 88%; animation-duration: 7s; animation-delay: 4s; width: 5rpx; height: 5rpx; }

@keyframes floatUp {
  0% { bottom: -10%; opacity: 0; }
  10% { opacity: 0.8; }
  90% { opacity: 0.3; }
  100% { bottom: 110%; opacity: 0; }
}

/* === CARD === */
.cyber-card {
  width: 640rpx;
  background: rgba(10,12,18,0.88);
  border: 2rpx solid rgba(255,255,255,0.08);
  position: relative;
  z-index: 1;
  overflow: hidden;
  backdrop-filter: blur(12rpx);
}

/* Border glow ring — pulses with the bg color */
.card-border-glow {
  position: absolute;
  top: -4rpx; left: -4rpx;
  right: -4rpx; bottom: -4rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  z-index: 0;
  pointer-events: none;
  animation: borderPulse 3s ease-in-out infinite;
}

@keyframes borderPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.7; }
}

/* Corner accents */
.card-corner {
  position: absolute;
  width: 36rpx; height: 36rpx;
  z-index: 3;
  pointer-events: none;
}
.card-corner-tl { top: 0; left: 0; border-top: 4rpx solid rgba(255,255,255,0.55); border-left: 4rpx solid rgba(255,255,255,0.55); }
.card-corner-tr { top: 0; right: 0; border-top: 4rpx solid rgba(255,255,255,0.55); border-right: 4rpx solid rgba(255,255,255,0.55); }
.card-corner-bl { bottom: 0; left: 0; border-bottom: 4rpx solid rgba(255,255,255,0.55); border-left: 4rpx solid rgba(255,255,255,0.55); }
.card-corner-br { bottom: 0; right: 0; border-bottom: 4rpx solid rgba(255,255,255,0.55); border-right: 4rpx solid rgba(255,255,255,0.55); }

/* Static scanline texture */
.scanline-static {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 4rpx,
    rgba(255,255,255,0.012) 4rpx,
    rgba(255,255,255,0.012) 8rpx
  );
  z-index: 2;
  pointer-events: none;
}

/* Sweeping scan beam */
.scanline-sweep {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15) 30%, rgba(255,255,255,0.35) 50%, rgba(255,255,255,0.15) 70%, transparent);
  z-index: 4;
  pointer-events: none;
  animation: scanSweep 3s linear infinite;
}

@keyframes scanSweep {
  0% { top: -2%; }
  100% { top: 102%; }
}

/* === CARD CONTENT === */
.card-header {
  padding: 40rpx 36rpx 0;
  z-index: 3;
  position: relative;
}

.cyber-label {
  display: block;
  font-size: 18rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.45);
  letter-spacing: 8rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.cyber-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.divider-dot {
  width: 8rpx; height: 8rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 50%;
  flex-shrink: 0;
  animation: dotFlicker 2s ease-in-out infinite;
}

@keyframes dotFlicker {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
}

.card-body {
  padding: 32rpx 36rpx 36rpx;
  z-index: 3;
  position: relative;
}

.cyber-tag {
  display: block;
  font-size: 17rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.30);
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

/* Model name */
.model-section { margin-bottom: 28rpx; }

.model-name {
  font-size: 44rpx;
  font-weight: 800;
  font-family: var(--font-sans);
  letter-spacing: 4rpx;
  line-height: 1.2;
}

/* Spectrum bar */
.spectrum-section { margin-bottom: 28rpx; }

.spectrum-bar {
  display: flex;
  height: 14rpx;
  border-radius: 7rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.spec-segment {
  animation: specShimmer 2s ease-in-out infinite;
}

.spec-segment:nth-child(2) { animation-delay: 0.3s; }
.spec-segment:nth-child(3) { animation-delay: 0.6s; }

@keyframes specShimmer {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.4); }
}

.rgba-value {
  font-size: 22rpx;
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.55);
  letter-spacing: 2rpx;
}

/* Diagnosis */
.diagnosis-section { margin-bottom: 24rpx; }

.diagnosis-text {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.8);
  line-height: 1.7;
  font-family: var(--font-sans);
}

/* Note */
.note-section { margin-bottom: 24rpx; }

.note-text {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.5);
  font-style: italic;
  line-height: 1.6;
}

/* Card footer */
.card-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.footer-hash {
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.20);
}

.footer-id {
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.20);
}

/* === ACTION BUTTONS === */
.action-row {
  position: relative;
  z-index: 1;
  width: 640rpx;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.cyber-btn-share {
  width: 100%;
  padding: 26rpx 0;
  background: rgba(255,255,255,0.04);
  border: 2rpx solid rgba(255,255,255,0.25);
  font-size: 28rpx;
  font-family: var(--font-mono);
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  letter-spacing: 4rpx;
  position: relative;
  overflow: hidden;
  border-radius: 0;
}

.cyber-btn-share:active {
  background: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.5);
}

.cyber-retake {
  background: transparent;
  border: none;
  padding: 8rpx 0;
  font-size: var(--font-size-xs);
  font-family: var(--font-mono);
  color: rgba(255,255,255,0.30);
  letter-spacing: 2rpx;
}
