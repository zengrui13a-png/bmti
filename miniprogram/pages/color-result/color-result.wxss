.neon-desk {
  min-height: 100vh;
  background: var(--paper-warm);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  position: relative; overflow: hidden;
}

/* Dynamic background */
.neon-bg-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
.nbg-gradient-1 { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.33; z-index: 1; }
.nbg-gradient-2 { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.20; z-index: 2; }
.nbg-gradient-3 { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.12; z-index: 3; }

/* Report card */
.neon-report {
  width: 640rpx; max-height: 65vh;
  background: rgba(255,255,255,0.85);
  border: 2.5rpx dashed var(--sketch-color);
  position: relative; z-index: 1;
  transform: rotate(-0.15deg);
  display: flex; flex-direction: column;
}

.corner-tick { position: absolute; width: 20rpx; height: 20rpx; z-index: 2; }
.ct-tl { top: -2rpx; left: -2rpx; border-top: 2.5rpx solid var(--neon-blue); border-left: 2.5rpx solid var(--neon-blue); }
.ct-tr { top: -2rpx; right: -2rpx; border-top: 2.5rpx solid var(--neon-pink); border-right: 2.5rpx solid var(--neon-pink); }
.ct-bl { bottom: -2rpx; left: -2rpx; border-bottom: 2.5rpx solid var(--neon-green); border-left: 2.5rpx solid var(--neon-green); }
.ct-br { bottom: -2rpx; right: -2rpx; border-bottom: 2.5rpx solid var(--neon-red); border-right: 2.5rpx solid var(--neon-red); }

.nr-header { padding: 32rpx 32rpx 0; flex-shrink: 0; }
.nr-label {
  display: block; font-size: 18rpx; font-family: var(--font-mono);
  color: var(--neon-blue); letter-spacing: 4rpx; text-align: center;
  text-shadow: 0 0 6rpx var(--neon-glow-blue);
}
.nr-divider { height: 0; border-top: 1.5rpx dashed var(--sketch-light); margin: 16rpx 0; }

.nr-body { padding: 0 32rpx 24rpx; overflow-y: auto; flex: 1; }

/* Identity */
.nr-id { margin-bottom: 8rpx; }
.nr-model {
  font-size: 36rpx; font-weight: 800; line-height: 1.3; margin-bottom: 12rpx;
}

.nr-spectrum {
  display: flex; height: 10rpx; border-radius: 5rpx;
  overflow: hidden; margin-bottom: 6rpx;
}

.nr-rgba {
  font-size: 18rpx; font-family: var(--font-mono); color: var(--ink-faint);
  letter-spacing: 1rpx;
}

/* Section labels */
.nr-section-label {
  font-size: 16rpx; font-family: var(--font-mono); color: var(--ink-faint);
  letter-spacing: 3rpx; margin: 20rpx 0 10rpx;
}

/* Paradox */
.nr-paradox {
  display: block; font-size: 24rpx; font-weight: 600; color: var(--ink);
  line-height: 1.7;
}

/* Body text */
.nr-body-text {
  display: block; font-size: 22rpx; color: var(--ink-light);
  line-height: 1.8;
}

/* Closing */
.nr-closing {
  margin-top: 24rpx; padding: 20rpx 20rpx 20rpx 16rpx;
  background: rgba(56,152,208,0.04);
  border-left: 3rpx solid var(--neon-blue);
  display: flex; gap: 10rpx;
  box-shadow: inset 0 0 16rpx rgba(56,152,208,0.03);
}

.nrc-marker { font-size: 18rpx; color: var(--neon-blue); flex-shrink: 0; margin-top: 2rpx; }
.nrc-text { font-size: 21rpx; font-weight: 600; color: var(--ink); line-height: 1.7; }

/* Footer */
.nr-footer {
  display: flex; justify-content: space-between;
  padding: 16rpx 32rpx;
  border-top: 1.5rpx dashed var(--sketch-light);
  flex-shrink: 0;
}

.nrf-code { font-size: 16rpx; font-family: var(--font-mono); color: var(--ink-faint); }
.nrf-id { font-size: 16rpx; font-family: var(--font-mono); color: var(--ink-faint); }

/* Actions */
.neon-actions {
  width: 640rpx; position: relative; z-index: 1;
  margin-top: 32rpx; display: flex; flex-direction: column;
  align-items: center; gap: 14rpx;
}

.neon-btn-share {
  width: 100%; padding: 24rpx 0;
  background: rgba(255,255,255,0.8);
  border: 2rpx solid var(--neon-blue);
  font-size: 26rpx; font-family: var(--font-mono);
  color: var(--neon-blue); letter-spacing: 3rpx; font-weight: 600;
  box-shadow: 0 0 18rpx var(--neon-glow-blue);
  border-radius: 0; transform: rotate(-0.1deg);
}

.neon-btn-share:active {
  background: rgba(56,152,208,0.1);
  box-shadow: 0 0 28rpx var(--neon-glow-blue);
}

.neon-retake { padding: 8rpx 0; }
.neon-retake text {
  font-size: 18rpx; font-family: var(--font-mono); color: var(--ink-faint);
}
