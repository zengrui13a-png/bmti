<view class="neon-desk" wx:if="{{result}}">
  <!-- Dynamic color background overlay -->
  <view class="neon-bg-overlay">
    <view class="nbg-gradient-1" style="background-image: {{gradients.g1}}"></view>
    <view class="nbg-gradient-2" style="background-image: {{gradients.g2}}"></view>
    <view class="nbg-gradient-3" style="background-image: {{gradients.g3}}"></view>
  </view>

  <!-- Main card -->
  <view class="neon-report">
    <view class="corner-tick ct-tl"></view>
    <view class="corner-tick ct-tr"></view>
    <view class="corner-tick ct-bl"></view>
    <view class="corner-tick ct-br"></view>

    <view class="nr-header">
      <text class="nr-label">>>> SYSTEM ANALYSIS COMPLETE</text>
      <view class="nr-divider"></view>
    </view>

    <view class="nr-body">
      <!-- Identity -->
      <view class="nr-id">
        <text class="nr-model" style="color: var(--bsod-blue)">{{result.name}}</text>
        <view class="nr-spectrum">
          <view class="ns-seg ns-r" style="background: rgba({{cvR}},0,0,0.7); flex: 1;"></view>
          <view class="ns-seg ns-g" style="background: rgba(0,{{cvG}},0,0.7); flex: 1;"></view>
          <view class="ns-seg ns-b" style="background: rgba(0,0,{{cvB}},0.7); flex: 1;"></view>
          <view class="ns-seg ns-t" style="background: {{bgColor}}; flex: 2;"></view>
        </view>
        <text class="nr-rgba">{{rgba}}</text>
      </view>

      <view class="nr-divider"></view>

      <!-- Paradox -->
      <view class="nr-section-label">核心发现</view>
      <text class="nr-paradox">{{analysis.paradox}}</text>

      <!-- Analysis -->
      <view class="nr-section-label">光谱分析</view>
      <text class="nr-body-text">{{analysis.analysis}}</text>

      <!-- Closing -->
      <view class="nr-closing">
        <view class="nrc-marker">◆</view>
        <text class="nrc-text">{{analysis.closing}}</text>
      </view>
    </view>

    <view class="nr-footer">
      <text class="nrf-code">0x{{result.color.replace('#','')}}</text>
      <text class="nrf-id">BMTI-RGBTI_v2.0</text>
    </view>
  </view>

  <!-- Actions -->
  <view class="neon-actions">
    <button class="neon-btn-share" open-type="share">
      ▸ 传输光谱报告
    </button>
    <view class="neon-retake" bindtap="onRetake">
      <text>⟲ 重新扫描</text>
    </view>
  </view>
</view>
