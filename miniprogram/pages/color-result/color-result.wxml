<view class="cyber-screen" wx:if="{{result}}">
  <view class="color-bg-overlay">
    <view class="bg-gradient-1" style="background-image: {{gradients.g1}}"></view>
    <view class="bg-gradient-2" style="background-image: {{gradients.g2}}"></view>
    <view class="bg-gradient-3" style="background-image: {{gradients.g3}}"></view>
    <view class="bg-glow-pulse" style="background-color: {{bgColor}}"></view>
    <view class="bg-rays-rotate"></view>
  </view>

  <view class="particles">
    <view class="particle p1"></view>
    <view class="particle p2"></view>
    <view class="particle p3"></view>
    <view class="particle p4"></view>
    <view class="particle p5"></view>
    <view class="particle p6"></view>
    <view class="particle p7"></view>
  </view>

  <!-- MAIN CARD -->
  <view class="cyber-card">
    <view class="card-border-glow"></view>
    <view class="card-corner card-corner-tl"></view>
    <view class="card-corner card-corner-tr"></view>
    <view class="card-corner card-corner-bl"></view>
    <view class="card-corner card-corner-br"></view>

    <view class="scanline-static"></view>
    <view class="scanline-sweep"></view>

    <!-- Header -->
    <view class="card-header">
      <text class="cyber-label">>>> SYSTEM ANALYSIS COMPLETE</text>
      <view class="cyber-divider">
        <view class="divider-dot"></view>
        <view class="divider-line"></view>
        <view class="divider-dot"></view>
      </view>
    </view>

    <view class="card-body">
      <!-- Model + Spectrum at top -->
      <view class="identity-block">
        <text class="identity-model" style="color: {{result.color}}; text-shadow: 0 0 20rpx {{result.color}}, 0 0 40rpx {{result.color}};">{{result.name}}</text>
        <view class="spectrum-mini">
          <view class="spec-seg" style="background: rgba({{cvR}},0,0,0.7); flex: 1;"></view>
          <view class="spec-seg" style="background: rgba(0,{{cvG}},0,0.7); flex: 1;"></view>
          <view class="spec-seg" style="background: rgba(0,0,{{cvB}},0.7); flex: 1;"></view>
          <view class="spec-seg" style="background: {{bgColor}}; flex: 2;"></view>
        </view>
        <text class="identity-rgba">{{rgba}}</text>
      </view>

      <!-- Divider -->
      <view class="section-divider">
        <view class="sd-line"></view>
        <text class="sd-tag">核心发现</text>
        <view class="sd-line"></view>
      </view>

      <!-- Paradox -->
      <text class="analysis-paradox">{{analysis.paradox}}</text>

      <!-- Divider -->
      <view class="section-divider">
        <view class="sd-line"></view>
        <text class="sd-tag">光谱分析</text>
        <view class="sd-line"></view>
      </view>

      <!-- Analysis body -->
      <text class="analysis-body">{{analysis.analysis}}</text>

      <!-- Closing block -->
      <view class="closing-block">
        <view class="closing-diamond">◆</view>
        <text class="closing-text">{{analysis.closing}}</text>
      </view>
    </view>

    <!-- Footer -->
    <view class="card-footer">
      <text class="footer-hash">0x{{result.color.replace('#','')}}</text>
      <text class="footer-id">BMTI-RGBTI_v2.0</text>
    </view>
  </view>

  <!-- Actions -->
  <view class="action-row">
    <button class="cyber-btn-share" open-type="share">
      <text class="btn-text">▸ 传输光谱报告</text>
    </button>
    <view class="cyber-retake" bindtap="onRetake">
      <text>⟲ 重新扫描</text>
    </view>
  </view>
</view>
