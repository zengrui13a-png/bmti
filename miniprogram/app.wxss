page {
  --bsod-blue: #0000AA;
  --win-gray: #C0C0C0;
  --win-title-blue: #000080;
  --win-white: #FFFFFF;
  --win-black: #000000;
  --win-shadow: #808080;
  --win-dark-shadow: #404040;
  --win-highlight: #DFDFDF;
  --font-mono: 'Courier New', monospace;
  --font-sans: 'SimSun', 'MS Sans Serif', sans-serif;

  background-color: var(--bsod-blue);
  color: var(--win-white);
  font-family: var(--font-mono);
  min-height: 100vh;
}
